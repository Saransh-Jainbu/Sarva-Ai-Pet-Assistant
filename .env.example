# Copy to .env.local and fill in. NEVER commit .env.local.

# Neon Postgres connection string
DATABASE_URL=""

# Sarvam AI API subscription key (https://dashboard.sarvam.ai)
SARVAM_API_KEY=""

SARVAM_CHAT_MODEL="sarvam-105b"
SARVAM_TTS_MODEL="bulbul:v2"
SARVAM_STT_MODEL="saaras:v3"
SARVAM_TTS_SPEAKER="anushka"
SARVAM_TTS_LANGUAGE="en-IN"

# Auth.js / Google sign-in
AUTH_SECRET=""            # generate: openssl rand -base64 32
AUTH_GOOGLE_ID=""         # Google Cloud OAuth client id (Web)
AUTH_GOOGLE_SECRET=""     # Google Cloud OAuth client secret
AUTH_URL="http://localhost:3000"
# Redirect URI to register in Google console: http://localhost:3000/api/auth/callback/google
